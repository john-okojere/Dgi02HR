# Django settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Lagos

# Static files
DJANGO_STATIC_URL=/static/
# DJANGO_STATIC_ROOT=C:\path\to\staticfiles

# Database (default is SQLite db.sqlite3)
DJANGO_DB_ENGINE=django.db.backends.sqlite3
# DJANGO_DB_NAME=db.sqlite3
# For Postgres/MySQL/etc:
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=microhr
# DJANGO_DB_USER=postgres
# DJANGO_DB_PASSWORD=secret
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432

# Security / proxy (useful in production)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True
# If behind a proxy that sets X-Forwarded-Proto:
# DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
# DJANGO_USE_X_FORWARDED_HOST=True
